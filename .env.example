# Copy this file to `.env` (which is gitignored) and adjust as needed.
# The real `.env` must never be committed — it may hold secrets.

# Which CRS approach serves /chat: echo | rag | multi_agent
# (only "echo" is implemented today; the others land in later phases)
CRS_APPROACH=echo

# LLM model name — used once real LLM calls are wired in (modeling phase)
CRS_LLM_MODEL=gpt-4o-mini

# Retrieval depth for RAG: how many movie documents to pull back
CRS_TOP_K=5

# Provider API key — leave blank here; set the real value only in `.env`
CRS_LLM_API_KEY=
